{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Basic Questionnaire Study",
    "version": "pilot",
    "authors": ["The reVISit Team"],
    "date": "2024-03-19",
    "description": "A simple questionnaire study",
    "organizations": ["University of Utah", "WPI"]
  },
  "uiConfig": {
    "contactEmail": "contact@revisit.dev",
    "helpTextPath": "basic-questionnaire-study/assets/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true
  },
  "components": {
    "introduction": {
      "type": "markdown",
      "path": "basic-questionnaire-study/assets/introduction.md",
      "response": []
    },
    "first-question-set": {
      "type": "questionnaire",
      "response": [
        {
          "id": "q1-long-text",
          "prompt": "Demo: Long Text Input",
          "required": true,
          "location": "aboveStimulus",
          "type": "longText",
          "placeholder": "Demo",
          "withDontKnow": true
        },
        {
          "id": "q2-short-text",
          "prompt": "Demo: Long Short Input",
          "required": true,
          "location": "aboveStimulus",
          "type": "shortText",
          "placeholder": "Demo"
        },
        {
          "id": "q3-demo-radio",
          "prompt": "Demo: Radio buttons",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": ["Option A", "Option B", "Option C"]
        },
        {
          "id": "q4-demo-dropdown",
          "prompt": "Demo: Dropdown",
          "required": true,
          "location": "aboveStimulus",
          "type": "dropdown",
          "options": ["Red", "Green", "Blue"]
        },
        {
          "id": "q5-demo-checkbox",
          "prompt": "Demo: Checkbox",
          "required": true,
          "location": "aboveStimulus",
          "type": "checkbox",
          "options": ["Apple", "Banana", "Cherry"]
        }
      ]
    },
    "second-question-set": {
      "type": "questionnaire",
      "response": [
        {
          "id": "q1-likert",
          "prompt": "Demo: likert scale",
          "required": true,
          "location": "aboveStimulus",
          "type": "likert",
          "leftLabel": "Strongly disagree",
          "rightLabel": "Strongly agree",
          "numItems": 5
        },
        {
          "id": "q2-slider",
          "prompt": "Demo: Slider",
          "required": true,
          "location": "aboveStimulus",
          "type": "slider",
          "step": 1,
          "spacing": 10,
          "options": [
            { "label": "0", "value": 0 },
            { "label": "10", "value": 10 },
            { "label": "20", "value": 20 },
            { "label": "30", "value": 30 },
            { "label": "40", "value": 40 },
            { "label": "50", "value": 50 }
          ]
        }
      ]
    },
    "figmaTask": {
      "type": "website",
      "path": "https://www.figma.com/embed?embed_host=share&url=https://www.figma.com/proto/rB4gLVNV3IxkYT57dh8Jkf/MetroSets-Tennis?node-id=2-787&scaling=contain&hide-ui=1",
      "instruction": "Please explore the prototype below. As you navigate, speak your thoughts aloud — tell us what you notice, what you expect, and anything that feels unclear or surprising.",
      "response": [
        {
          "id": "q3-demo-radio",
          "prompt": "Demo: Radio buttons",
          "required": true,
          "location": "sidebar",
          "type": "radio",
          "options": ["Option A", "Option B", "Option C"]
        }
      ]
    }
  },
  "sequence": {
    "order": "fixed",
    "components": ["introduction", "figmaTask", "first-question-set", "second-question-set"]
  }
}
