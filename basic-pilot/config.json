    "upset-tennis": {
      "type": "website",
      "path": "https://embed.figma.com/proto/rB4gLVNV3IxkYT57dh8Jkf/UpSet-Tennis?node-id=105-7098&content-scaling=responsive&scaling=min-zoom&hotspot-hints=0&hide-ui=1&embed-host=share",
      "nextButtonLocation": "sidebar",
      "style": {
        "width": "1000px",
        "margin": "0 auto"
      },
      "response": [
        {
          "id": "q1-task",
          "prompt": "How many sets are represented in this dataset?",
          "required": true,
          "location": "sidebar",
          "type": "numerical"
        },
        {
          "id": "q2-task",
          "prompt": "How many players have won both the French Open and the Australian Open?",
          "required": true,
          "location": "sidebar",
          "type": "numerical"
        },
        {
          "id": "q3-task",
          "prompt": "Which Grand Slam tournament has the most winners in this dataset?",
          "required": true,
          "location": "sidebar",
          "type": "radio",
          "options": ["Wimbledon", "US Open", "French Open", "Australian Open"]
        },
        {
          "id": "q4-task",
          "prompt": "How many players belong to the largest intersection?",
          "required": true,
          "location": "sidebar",
          "type": "numerical"
        },
        {
          "id": "q5-task",
          "prompt": "Do any players appear in both the Womens and Wimbledon sets?",
          "required": true,
          "location": "sidebar",
          "type": "radio",
          "options": ["Yes", "No"]
        },
        {
          "id": "q6-task",
          "prompt": "The largest intersection has 13 players, which sets do they belong to?",
          "required": true,
          "location": "sidebar",
          "type": "checkbox",
          "options": [
            "Wimbledon",
            "US Open",
            "French Open",
            "Autralian Open",
            "Mens",
            "Womens"
          ]
        },
        {
          "id": "q7-task",
          "prompt": "What is the most common combination of sets that players belong to?",
          "required": true,
          "location": "sidebar",
          "type": "radio",
          "options": [
            "Mens & French Open",
            "Womens & Australian Open",
            "Mens & Australian Open",
            "Womens & French Open"
          ]
        },
        {
          "id": "q8-task",
          "prompt": "Which sets overlap with the most other sets?",
          "required": true,
          "location": "sidebar",
          "type": "checkbox",
          "options": [
            "Wimbledon",
            "US Open",
            "French Open",
            "Autralian Open",
            "Mens",
            "Womens"
          ]
        },
        {
          "id": "q9-task",
          "prompt": "How many sets make up the most common combination?",
          "required": true,
          "location": "sidebar",
          "type": "numerical"
        },
        {
          "id": "q10-task",
          "prompt": "Is the French Open part of the largest intersection?",
          "required": true,
          "location": "sidebar",
          "type": "radio",
          "options": ["Yes", "No"]
        },
        {
          "id": "q11-task",
          "prompt": "Which tournaments does Wimbledon share winners with?",
          "required": true,
          "location": "sidebar",
          "type": "checkbox",
          "options": [
            "US Open",
            "French Open",
            "Autralian Open",
            "Mens",
            "Womens"
          ]
        },
        {
          "id": "q12-task",
          "prompt": "Is there any player who has won all Grand Slams in both categories?",
          "required": true,
          "location": "sidebar",
          "type": "radio",
          "options": ["Yes", "No"]
        }
      ]
    },
