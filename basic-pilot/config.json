    "demographics": {
      "type": "questionnaire",
      "response": [
        {
          "id": "age",
          "type": "numerical",
          "prompt": "What is your age?",
          "required": true,
          "location": "aboveStimulus",
          "placeholder": "Enter your age",
          "min": 18,
          "max": 100
        },
        {
          "id": "gender",
          "type": "radio",
          "prompt": "What is your gender?",
          "required": true,
          "location": "aboveStimulus",
          "options": [
            "Man",
            "Woman",
            "Non-binary / gender non-conforming",
            "Prefer to self-describe",
            "Prefer not to say"
          ]
        },
        {
          "id": "education",
          "type": "radio",
          "prompt": "What is the highest level of education you have completed?",
          "required": true,
          "location": "aboveStimulus",
          "options": [
            "High school diploma or equivalent",
            "Some college or associate degree",
            "Bachelor's degree",
            "Master's degree",
            "Doctoral or professional degree",
            "Prefer not to say"
          ]
        },
        {
          "id": "vizExperience",
          "type": "likert",
          "prompt": "How much experience do you have working with data visualizations (charts, graphs, diagrams)?",
          "required": true,
          "location": "aboveStimulus",
          "numItems": 5,
          "leftLabel": "No experience",
          "rightLabel": "Expert"
        },
        {
          "id": "setFamiliarity",
          "type": "likert",
          "prompt": "How familiar are you with set diagrams specifically (e.g. Venn diagrams, UpSet plots)?",
          "required": true,
          "location": "aboveStimulus",
          "numItems": 5,
          "leftLabel": "Never seen one",
          "rightLabel": "Use them regularly"
        },
        {
          "id": "visionIssues",
          "type": "longText",
          "prompt": "Do you have any visual perception issues (for example: color vision deficiency, low vision, astigmatism)? If none, write \"None\".",
          "required": true,
          "location": "aboveStimulus",
          "placeholder": "Type here..."
        },
        {
          "id": "strategies",
          "type": "longText",
          "prompt": "Did you use any strategies or notice any patterns while completing the tasks?",
          "required": true,
          "location": "aboveStimulus",
          "placeholder": "Type here..."
        }
      ]
    },
    "studystart": {
      "type": "markdown",
      "path": "basic-pilot/assets/studystart.md",
      "response": []
    },
    "tutorial": {
      "type": "markdown",
      "path": "basic-pilot/assets/tutorial.md",
      "response": []
    },
